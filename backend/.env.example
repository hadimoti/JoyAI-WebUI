HOST=0.0.0.0
PORT=8080

# Telegram bot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Gmail SMTP (for email auth)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youremail@gmail.com
SMTP_PASS=your16charAppPassword

# Hermes local API server (run `hermes gateway` or the desktop app first)
HERMES_API_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=YOUR_API_SERVER_KEY_HERE
